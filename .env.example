# BAREKAT Health Analytics - Environment Configuration

# Application
BAREKAT_ENV=development
API_PORT=8000
DASHBOARD_PORT=8501
JWT_SECRET=change-me-to-a-secure-random-string
AUTH_USE_DATABASE=true
AUTH_DEV_FALLBACK=true
DB_AUTO_MIGRATE=true
CORS_ORIGINS=*
AUTH_USE_DATABASE=true
AUTH_DEV_FALLBACK=true
DB_AUTO_MIGRATE=true
CORS_ORIGINS=*
JWT_EXPIRE_MINUTES=60

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=barekat
POSTGRES_PASSWORD=barekat_secret
POSTGRES_DB=barekat_health

# MinIO (Object Storage - DICOM, HL7, raw files)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=barekat_minio
MINIO_ROOT_PASSWORD=barekat_minio_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW=health-raw
MINIO_BUCKET_PROCESSED=health-processed
MINIO_BUCKET_LAKE=health-lake

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PORT=9092
KAFKA_TOPIC_ADMISSIONS=health.admissions
KAFKA_TOPIC_LAB_RESULTS=health.lab_results
KAFKA_TOPIC_ALERTS=health.alerts
KAFKA_TOPIC_EVENTS_RAW=health.events.raw
KAFKA_TOPIC_HL7=health.hl7
KAFKA_TOPIC_FHIR=health.fhir

# PACS / DICOM imaging
PACS_HOST=localhost
PACS_PORT=4242
PACS_AE_TITLE=ORTHANC
PACS_CALLING_AE=BAREKAT
PACS_ORTHANC_URL=http://localhost:8042
DICOM_DATA_PATH=./data/dicom

# FHIR connector defaults (override per-request)
FHIR_DEFAULT_PROFILE=international_hapi
FHIR_HAPI_BASE_URL=https://hapi.fhir.org/baseR4

# Spark
SPARK_MASTER_URL=spark://localhost:7077
SPARK_MASTER_PORT=8080
SPARK_MASTER_UI_PORT=7077

# Data paths
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_MODELS_PATH=./data/models

# ML
ML_READMISSION_THRESHOLD=0.7
ML_CLUSTER_COUNT=5

# Dashboard
DASHBOARD_DATA_SOURCE=auto

# ETL scheduling (Celery Beat)
ETL_MAX_RETRIES=3
ETL_RETRY_DELAY_SECONDS=60
ETL_INCREMENTAL_MINUTE=0
ETL_FULL_HOUR=2
ETL_FULL_MINUTE=0

# ML retrain schedule (Celery Beat)
ML_RETRAIN_DAY_OF_WEEK=0
ML_RETRAIN_HOUR=3
ML_RETRAIN_MINUTE=0
ML_MAX_RETRIES=2

# Compliance & Privacy (HIPAA / GDPR / domestic)
AUDIT_ENABLED=true
AUDIT_LOG_IP=true
COMPLIANCE_FRAMEWORK=all
PSEUDONYMIZATION_SALT=change-me-pseudonym-salt
DATA_RETENTION_ENABLED=true
RETENTION_PURGE_HOUR=4
RETENTION_PURGE_MINUTE=0
DEFAULT_RETENTION_DAYS=2555
REQUIRE_CONSENT_FOR_RESEARCH=false

# Security hardening
TLS_ENABLED=false
SECRETS_BACKEND=env
PHI_ENCRYPTION_ENABLED=false
PHI_ENCRYPTION_KEY=
MFA_REQUIRED_FOR_ADMIN=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_LOGIN_PER_MINUTE=10
WAF_ENABLED=true

# Notifications (email / SMS critical alerts)
NOTIFICATIONS_ENABLED=false
ALERT_NOTIFY_MIN_SEVERITY=critical
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=barekat@localhost
SMTP_USE_TLS=true
SMS_PROVIDER=kavenegar
KAVENEGAR_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Weekly reports schedule (Celery Beat — Sunday 08:00)
WEEKLY_REPORT_DAY_OF_WEEK=6
WEEKLY_REPORT_HOUR=8
WEEKLY_REPORT_MINUTE=0

# Mobile PWA
MOBILE_PWA_ENABLED=true
MOBILE_API_BASE_URL=http://localhost:8000

# Data Lake (MinIO medallion: Bronze / Silver / Gold)
LAKE_ENABLED=true
LAKE_TABLE_FORMAT=delta
LAKE_SPARK_ENABLED=false
LAKE_BATCH_DAY_OF_WEEK=0
LAKE_BATCH_HOUR=1
LAKE_BATCH_MINUTE=0

# Observability (Prometheus / Grafana / Loki)
OBSERVABILITY_ENABLED=true
METRICS_REFRESH_SECONDS=60
DRIFT_PSI_THRESHOLD=0.2
DRIFT_AUC_DROP_THRESHOLD=0.05
DRIFT_CHECK_HOUR=5
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=barekat_grafana
PROMETHEUS_PORT=9090
