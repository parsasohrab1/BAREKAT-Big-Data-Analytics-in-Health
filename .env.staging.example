# BAREKAT Staging Environment
# Copy to .env.staging and adjust secrets before deploy

BAREKAT_ENV=staging
API_PORT=8001
DASHBOARD_PORT=8502

JWT_SECRET=staging-change-me-to-a-secure-random-string
JWT_EXPIRE_MINUTES=60

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=barekat
POSTGRES_PASSWORD=barekat_staging_secret
POSTGRES_DB=barekat_health_staging

MINIO_ROOT_USER=barekat_minio
MINIO_ROOT_PASSWORD=barekat_minio_staging_secret
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

REDIS_HOST=localhost
REDIS_PORT=6380

DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_MODELS_PATH=./data/models

DASHBOARD_DATA_SOURCE=postgres
