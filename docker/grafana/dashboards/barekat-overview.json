{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(barekat_http_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "title": "ETL Runs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "increase(barekat_etl_runs_total[1h])",
          "legendFormat": "{{mode}} {{status}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "title": "Model AUC",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "thresholds": { "steps": [
        { "color": "red", "value": 0 },
        { "color": "yellow", "value": 0.65 },
        { "color": "green", "value": 0.75 }
      ]}}},
      "targets": [
        { "expr": "barekat_ml_model_auc", "legendFormat": "{{model_name}}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "title": "Model Drift (PSI)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "min": 0, "max": 0.5, "thresholds": { "steps": [
        { "color": "green", "value": 0 },
        { "color": "yellow", "value": 0.15 },
        { "color": "red", "value": 0.2 }
      ]}}},
      "targets": [
        { "expr": "barekat_ml_drift_psi", "legendFormat": "{{model_name}}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "title": "Active Alerts by Severity",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "barekat_active_alerts", "legendFormat": "{{severity}}", "refId": "A" }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "title": "Service Logs (Loki)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "{service=~\"api|celery-worker|celery-beat|faust-worker\"}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "loki", "uid": "Loki" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["barekat", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "BAREKAT Platform Overview",
  "uid": "barekat-overview",
  "version": 1
}
