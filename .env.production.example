# BAREKAT Production Environment
# Copy to .env.production — NEVER commit real secrets

BAREKAT_ENV=production
API_PORT=8000
DASHBOARD_PORT=8501

JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRE_MINUTES=30

POSTGRES_USER=barekat
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=barekat_health

MINIO_ROOT_USER=barekat_minio
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_MINIO_PASSWORD

DATA_RAW_PATH=/app/data/raw
DATA_PROCESSED_PATH=/app/data/processed
DATA_MODELS_PATH=/app/data/models

DASHBOARD_DATA_SOURCE=postgres

AUDIT_ENABLED=true
AUDIT_LOG_IP=true
COMPLIANCE_FRAMEWORK=all
PSEUDONYMIZATION_SALT=REPLACE_WITH_STRONG_PSEUDONYM_SALT
DATA_RETENTION_ENABLED=true
RETENTION_PURGE_HOUR=4

TLS_ENABLED=true
SECRETS_BACKEND=docker
PHI_ENCRYPTION_ENABLED=true
MFA_REQUIRED_FOR_ADMIN=true
RATE_LIMIT_ENABLED=true
WAF_ENABLED=true
MINIO_SECURE=true
